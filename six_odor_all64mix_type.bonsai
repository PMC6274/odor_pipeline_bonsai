it == 16 ? "0,0,3,0,6,0,700" :
it == 17 ? "0,2,0,5,0,7,600" :
it == 18 ? "0,0,0,0,6,0,800" :
it == 19 ? "0,2,3,5,0,7,500" :
it == 20 ? "0,0,0,0,0,0,900" :
it == 21 ? "1,2,0,5,6,0,500" :
it == 22 ? "0,2,0,0,6,7,600" :
it == 23 ? "0,0,3,0,6,7,600" :
it == 24 ? "0,0,0,0,6,7,700" :
it == 25 ? "0,2,0,5,6,7,500" :
it == 26 ? "0,0,3,0,0,0,800" :
it == 27 ? "0,0,3,5,0,7,600" :
it == 28 ? "0,2,3,5,6,7,400" :
it == 29 ? "1,2,3,5,6,0,400" :
it == 30 ? "1,2,3,5,6,7,300" :
it == 31 ? "0,0,0,5,0,7,700" :
it == 32 ? "1,0,3,5,6,7,400" :
it == 33 ? "1,0,0,0,0,0,800" :
it == 34 ? "1,2,3,0,6,0,500" :
it == 35 ? "1,0,0,5,0,0,700" :
it == 36 ? "1,0,3,0,0,7,600" :
it == 37 ? "0,2,3,0,6,7,500" :
it == 38 ? "1,2,0,0,6,7,500" :
it == 39 ? "1,2,3,0,0,7,500" :
it == 40 ? "1,0,0,0,6,0,700" :
it == 41 ? "0,0,3,5,0,0,700" :
it == 42 ? "1,0,3,5,0,0,600" :
it == 43 ? "1,0,0,5,6,0,600" :
it == 44 ? "1,2,3,5,0,0,500" :
it == 45 ? "1,2,0,0,0,7,600" :
it == 46 ? "1,0,3,5,6,0,500" :
it == 47 ? "1,0,3,0,0,0,700" :
it == 48 ? "0,2,0,0,6,0,700" :
it == 49 ? "0,2,3,0,6,0,600" :
it == 50 ? "0,0,0,5,0,0,800" :
it == 51 ? "1,0,0,5,6,7,500" :
it == 52 ? "1,0,0,5,0,7,600" :
