it == 21 ? "0,0,3,0,0,0,800" :
it == 22 ? "0,0,3,0,0,0,800" :
it == 23 ? "0,0,3,0,0,0,800" :
it == 24 ? "0,0,3,0,0,0,800" :
it == 25 ? "0,0,3,0,0,0,800" :
it == 26 ? "0,0,3,0,0,0,800" :
it == 27 ? "0,0,3,0,0,0,800" :
it == 28 ? "0,0,3,0,0,0,800" :
it == 29 ? "0,0,3,0,0,0,800" :
it == 30 ? "0,0,3,0,0,0,800" :
it == 31 ? "0,0,0,0,6,0,800" :
it == 32 ? "0,0,0,0,6,0,800" :
it == 33 ? "0,0,0,0,6,0,800" :
it == 34 ? "0,0,0,0,6,0,800" :
it == 35 ? "0,0,0,0,6,0,800" :
